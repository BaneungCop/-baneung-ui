  "scripts": {
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsup",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsup --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "size": "size-limit",
    "clean": "rimraf dist .turbo"
  },
  "size-limit": [
    {
      "name": "main bundle (ESM, full)",
      "path": "dist/index.js",
      "limit": "120 kB",
      "gzip": true
    },
    {
      "name": "Button (subpath)",
      "path": "dist/components/button/index.js",
      "limit": "5 kB",
      "gzip": true
    },
    {
      "name": "Input (subpath)",
      "path": "dist/components/input/index.js",
      "limit": "5 kB",
      "gzip": true
    },
    {
      "name": "Select (cmdk + Popover, single+multi+searchable)",
      "path": "dist/components/select/index.js",
      "limit": "20 kB",
      "gzip": true
    },
    {
      "name": "DataTable (tanstack-table)",
      "path": "dist/components/data-table/index.js",
      "limit": "30 kB",
      "gzip": true
    },
    {
      "name": "styles.css",
      "path": "dist/styles.css",
      "limit": "20 kB",
      "gzip": true
    }
  ],
